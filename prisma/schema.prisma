generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
}

model Property {
  id          String   @id @default(cuid())
  slug        String   @unique
  titleEs     String
  titleEn     String?
  descriptionEs String
  descriptionEn String?
  price       Float
  priceFrom   Boolean  @default(false)
  priceType   String   @default("venta")
  currency    String   @default("CLP")
  zoneEs      String
  zoneEn      String?
  cityEs      String
  cityEn      String?
  address     String?
  province    String?
  country     String?  @default("Chile")
  marketRegion String  @default("latam")
  postalCode  String?
  addressVisibility String @default("zona")
  latitude    Float?
  longitude   Float?
  type        String
  status      String   @default("disponible")
  published   Boolean  @default(false)
  featured    Boolean  @default(false)
  featuredBeforeUnpublish Boolean @default(false)
  bedrooms    Int?
  bathrooms   Int?
  area        Float?
  totalArea   Float?
  builtArea   Float?
  yearBuilt   Int?
  expenses    Float?
  parking     Int?
  internalCode String?
  agentName   String?
  agentPhone  String?
  agentEmail  String?
  frontage    Float?
  depth       Float?
  zoning      String?
  mapUrl      String?
  virtualTourUrl String?
  lotSurfaceM2 Float?
  totalLots   Int?
  availableLots Int?
  stageName   String?
  paymentTerms String?
  commissionPercent Float?
  operationalExpenses String?
  reservationAmount Float?
  waterStatus String?
  electricityStatus String?
  accessType  String?
  roadType    String?
  hasOwnRol   Boolean  @default(false)
  availabilityNotes String?
  commercialNotes String?
  distanceHighlights String @default("[]")
  services    String   @default("[]")
  amenities   String   @default("[]")
  images      String   @default("[]")
  coverImage  String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  leads       Lead[]

  // SEO Enterprise autogestionables
  seoTitleEs      String?
  seoTitleEn      String?
  seoDescriptionEs String?
  seoDescriptionEn String?
  customCanonical  String?
  ogImage          String?

  @@index([published, featured, createdAt])
  @@index([published, type, priceType])
  @@index([published, marketRegion])
  @@index([published, country])
  @@index([published, zoneEs])
  @@index([published, zoneEn])
  @@index([published, price])
  @@index([published, bedrooms])
  @@index([published, availableLots])
  @@index([published, lotSurfaceM2])
}

model Lead {
  id         String    @id @default(cuid())
  name       String
  email      String
  phone      String?
  message    String?
  status     String    @default("pendiente")
  propertyId String?
  property   Property? @relation(fields: [propertyId], references: [id])
  leadSource String    @default("web_form")
  landingPath String?
  referrer   String?
  utmSource  String?
  utmMedium  String?
  utmCampaign String?
  utmContent String?
  utmTerm    String?
  createdAt  DateTime  @default(now())

  @@index([createdAt])
  @@index([propertyId])
  @@index([status, createdAt])
  @@index([utmCampaign, createdAt])
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String
  role      String   @default("admin")
  createdAt DateTime @default(now())
}

model HomeHeroSettings {
  id           String   @id @default("main")
  imageUrl     String?
  titleLine1Es String?
  titleLine2Es String?
  subtitleEs   String?
  titleLine1En String?
  titleLine2En String?
  subtitleEn   String?
  updatedAt    DateTime @updatedAt
}

model SiteSeoSettings {
  id                       String   @id @default("main")
  siteName                 String   @default("Calafate Propiedades")
  titleTemplate            String   @default("%s | Calafate Propiedades")
  defaultTitleEs           String   @default("Calafate Propiedades | Parcelas, terrenos y proyectos en Chile")
  defaultDescriptionEs     String   @default("Compra parcelas, terrenos y loteos seleccionados con Calafate Propiedades. Proyectos con informacion clara, tours 360, precios desde y asesoria directa.")
  defaultTitleEn           String?
  defaultDescriptionEn     String?
  keywords                 String   @default("[]")
  canonicalBaseUrl         String   @default("https://calafetapropiedades.vercel.app")
  defaultOgImage           String?
  googleSiteVerification   String?
  googleAnalyticsId        String?
  metaPixelId              String?
  allowIndexing            Boolean  @default(true)
  robotsDisallow           String   @default("[\"/admin/\",\"/api/\",\"/gracias\"]")
  updatedAt                DateTime @updatedAt
}

model StaticPage {
  id               String   @id @default(cuid())
  slug             String   @unique
  titleEs          String
  titleEn          String?
  contentEs        String
  contentEn        String?
  published        Boolean  @default(false)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  // SEO Enterprise autogestionables
  seoTitleEs       String?
  seoTitleEn       String?
  seoDescriptionEs String?
  seoDescriptionEn String?
  customCanonical  String?
  ogImage          String?

  @@index([published, createdAt])
}
